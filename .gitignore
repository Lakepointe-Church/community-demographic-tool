# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# large LODES source caches (re-fetched by scripts/import-lodes.ts; do not commit)
data/lodes-*.csv.gz

# HUD USPS address vacancy downloads (licensed dataset, gov/nonprofit only — do not commit)
data/hud-usps-*.csv

# IRS SOI ZIP income source cache (~200 MB; re-fetched by scripts/import-soi.ts)
data/soi-zpallagi-*.csv

# Zillow ZHVI source cache (~120 MB; streamed/re-fetched by scripts/import-zillow.ts)
data/zillow-zhvi-zip.csv

# Attendee export from Rock RMS — DB-only, NEVER commit (privacy boundary, spec §0.6/§2.3)
data/FamilyCount*.csv

# TEA PEIMS enrollment manual downloads (re-downloadable; loaded by scripts/import-tea.ts)
data/tea-enrollment-*.csv

# TDC county projections manual download (re-downloadable; loaded by scripts/import-tdc.ts)
data/tdc-projections-*.csv

# IRS SOI county migration source cache (re-fetched by scripts/import-soi-migration.ts)
data/countyin*flow*.csv
